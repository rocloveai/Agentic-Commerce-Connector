# =============================================================================
# Nexus Payment Provider (NUPS/1.5) — required when PAYMENT_PROVIDER=nexus
# =============================================================================
# Nexus signs EIP-712 payment quotes off-chain and escrows USDC/XSGD on-chain.
# The signer key is a hot key for quote signing only — it does NOT receive
# funds. Payouts go to MERCHANT_PAYMENT_ADDRESS after settlement.

# -----------------------------------------------------------------------------
# Signer wallet
# -----------------------------------------------------------------------------
# Private key that signs NUPS quotes. 0x-prefixed 32-byte hex.
# Get it from:
#   - Generate a fresh key: openssl rand -hex 32 then prefix with 0x
#   - Or via viem: `const pk = generatePrivateKey()` in any tmp Node script
# SECURITY: dedicated hot wallet; never reuse the payout wallet key.
MERCHANT_SIGNER_PRIVATE_KEY=0x

# -----------------------------------------------------------------------------
# Payout address
# -----------------------------------------------------------------------------
# On-chain address that receives settled stablecoin funds after buyers pay.
# Can be the same key as the signer OR (recommended) a cold/custodial address.
MERCHANT_PAYMENT_ADDRESS=0x

# -----------------------------------------------------------------------------
# Nexus network endpoints
# -----------------------------------------------------------------------------
# nexus-core API: orchestrates checkout groups and webhooks.
NEXUS_CORE_URL=https://api.nexus.platon.network

# Buyer-facing checkout page base URL. Sessions return
# `${CHECKOUT_BASE_URL}/checkout/{group_id}` as the continue_url.
CHECKOUT_BASE_URL=https://nexus.platon.network

# On-chain network the escrow contract lives on.
NEXUS_CHAIN_ID=20250407

# -----------------------------------------------------------------------------
# Webhook verification
# -----------------------------------------------------------------------------
# Shared secret used by nexus-core to HMAC-sign webhook POSTs to /webhook.
# Get it from: your nexus-core merchant registration (POST /api/market/register
# returns a `webhook_secret`).
NEXUS_WEBHOOK_SECRET=
# Backward-compatible alias; NEXUS_WEBHOOK_SECRET is preferred.
WEBHOOK_SECRET=
