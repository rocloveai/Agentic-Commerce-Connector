# =============================================================================
# Shopify adapter — required when PLATFORM=shopify
# =============================================================================
# Shopify can be configured in one of two modes. The loader auto-detects which
# based on whether SHOPIFY_CLIENT_ID is set:
#
#   - OAuth mode (recommended, set SHOPIFY_CLIENT_ID):
#       The connector performs a standard Shopify OAuth install flow. The
#       merchant clicks a link, approves scopes on Shopify, and the connector
#       receives an offline token that's persisted (encrypted at rest) for
#       reuse. Scope upgrades and uninstall cleanup are handled automatically.
#       Requires a public HTTPS callback URL.
#
#   - Manual mode (fallback, leave SHOPIFY_CLIENT_ID empty):
#       The merchant creates a Custom app in Shopify admin → Develop apps,
#       toggles scopes by hand, and pastes Admin + Storefront tokens into env.
#       Works offline / without a Partners account, good for dev/demo.
#
# Pick one. Setting SHOPIFY_CLIENT_ID selects OAuth; if it's set, the manual
# token vars below are ignored.

# -----------------------------------------------------------------------------
# OAuth mode — recommended
# -----------------------------------------------------------------------------
# Create a Custom-Distribution app:
#   https://partners.shopify.com/apps → Create app → Create app manually
# In the app configuration set:
#   App URL              : https://<your-acc>/admin/shopify
#   Allowed redirection  : https://<your-acc>/auth/shopify/callback
#   API scopes           : read_products, read_inventory, write_orders, read_orders
# Then copy the generated Client ID / Client secret below.

SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Comma-separated list. Leave unset to accept the default below.
# Default: read_products,read_inventory,write_orders,read_orders
SHOPIFY_OAUTH_SCOPES=

# Public HTTPS URL Shopify redirects to after consent. Must match exactly the
# "Allowed redirection URL" configured in Partners. Leave empty to derive as
# ${SELF_URL}/auth/shopify/callback at startup (Phase 3 feature).
SHOPIFY_OAUTH_REDIRECT=

# -----------------------------------------------------------------------------
# OAuth mode — storage backend (choose ONE)
# -----------------------------------------------------------------------------
# The connector stores one row per Shopify installation (encrypted tokens,
# granted scopes, timestamps) using one of two backends:
#
#   a) SQLite (default). Zero setup — a file under the data dir, suitable for
#      single-shop self-hosted deployments. Leave DATABASE_URL empty.
#      Set ACC_DATA_DIR to move the file; defaults to ./acc-data relative
#      to the working directory. The SQLite file lives at
#      <data-dir>/db/acc.sqlite.
#
#   b) Postgres (opt-in). Used automatically when DATABASE_URL is set to a
#      postgres://… URL. Recommended for hosted / multi-tenant deployments.
ACC_DATA_DIR=./acc-data

# -----------------------------------------------------------------------------
# OAuth mode — token encryption at rest (required when OAuth is active)
# -----------------------------------------------------------------------------
# 32-byte AES-256-GCM key, hex-encoded (64 chars). Used to encrypt the admin
# and storefront tokens persisted to the installation store.
#
# Generate one with:
#   openssl rand -hex 32
#
# Store it in a secret manager — if it leaks, rotate it and force re-install.
ACC_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Manual mode — fallback
# -----------------------------------------------------------------------------
# Only used when SHOPIFY_CLIENT_ID is empty.

# Format: https://<your-store>.myshopify.com  (no trailing slash)
# Get it from: the URL of your Shopify admin.
SHOPIFY_STORE_URL=https://my-store.myshopify.com

# Storefront API token (read — required for catalog browse).
# Get it from: Shopify admin → Settings → Apps and sales channels
#   → Develop apps → (your app) → Configuration → Storefront API integration
#   → enable read_products, read_inventory
#   → API credentials → Storefront API access token
SHOPIFY_STOREFRONT_TOKEN=

# Admin API token (write — required for order writeback).
# Get it from the same custom app:
#   Configuration → Admin API integration → enable write_orders, read_orders
#   → API credentials → Admin API access token  (starts with shpat_)
# Grant the narrowest scopes you need.
SHOPIFY_ADMIN_TOKEN=shpat_

# -----------------------------------------------------------------------------
# Shared settings (both modes)
# -----------------------------------------------------------------------------
# Shopify releases quarterly. Pin to a stable version; bump on your schedule.
SHOPIFY_API_VERSION=2025-07
