# =============================================================================
# Shopify adapter — required when PLATFORM=shopify
# =============================================================================
# Shopify uses two distinct APIs: the Storefront API (read — products) and
# the Admin API (write — orders). You need tokens for both if you want order
# writeback; Storefront alone is enough for browse-only.

# -----------------------------------------------------------------------------
# Store URL
# -----------------------------------------------------------------------------
# Format: https://<your-store>.myshopify.com  (no trailing slash)
# Get it from: the URL of your Shopify admin.
SHOPIFY_STORE_URL=https://my-store.myshopify.com

# -----------------------------------------------------------------------------
# Storefront API token (read — required)
# -----------------------------------------------------------------------------
# Get it from:
#   Shopify admin → Settings → Apps and sales channels → Develop apps
#   → (create or open your app) → Configuration → Storefront API integration
#   → enable read_products, read_inventory
#   → API credentials → Storefront API access token
SHOPIFY_STOREFRONT_TOKEN=

# -----------------------------------------------------------------------------
# Admin API token (write — required for order writeback)
# -----------------------------------------------------------------------------
# Get it from the same custom app as above:
#   Configuration → Admin API integration → enable write_orders, read_orders
#   → API credentials → Admin API access token  (starts with shpat_)
# Grant the narrowest scopes you need: write_orders and read_orders.
SHOPIFY_ADMIN_TOKEN=shpat_

# -----------------------------------------------------------------------------
# API version pin
# -----------------------------------------------------------------------------
# Shopify releases quarterly. Pin to a stable version; bump on your schedule.
SHOPIFY_API_VERSION=2025-07
