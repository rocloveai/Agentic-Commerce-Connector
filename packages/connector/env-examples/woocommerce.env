# =============================================================================
# WooCommerce adapter — required when PLATFORM=woocommerce
# =============================================================================
# WooCommerce uses a single REST v3 endpoint with HTTP Basic auth.
# HTTPS is mandatory — startup will throw on plain-http URLs.

# -----------------------------------------------------------------------------
# Store URL
# -----------------------------------------------------------------------------
# Must be HTTPS. No trailing slash.
# Get it from: the public URL of your WordPress site hosting WooCommerce.
WOO_BASE_URL=https://my-store.example.com

# -----------------------------------------------------------------------------
# REST API credentials
# -----------------------------------------------------------------------------
# Get them from:
#   WooCommerce admin → Settings → Advanced → REST API
#   → Add Key  (Description: "Agentic Commerce Connector";
#                User: an admin; Permissions: Read/Write)
#   → Generate API Key
# The secret is shown ONCE — copy it immediately.
WOO_CONSUMER_KEY=ck_
WOO_CONSUMER_SECRET=cs_

# -----------------------------------------------------------------------------
# API version
# -----------------------------------------------------------------------------
# Current stable is "wc/v3"; older WP sites may only support "wc/v2".
WOO_API_VERSION=wc/v3

# -----------------------------------------------------------------------------
# Network tuning
# -----------------------------------------------------------------------------
# Cheap/shared hosting often throttles; tune retries accordingly.
WOO_REQUEST_TIMEOUT_MS=15000
WOO_MAX_RETRIES=3
