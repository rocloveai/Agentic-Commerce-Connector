# =============================================================================
# Base configuration — required by every deployment
# =============================================================================
# Infra-level settings, independent of commerce platform and payment provider.

# -----------------------------------------------------------------------------
# Platform + Provider selection
# -----------------------------------------------------------------------------
# Which commerce backend adapter to load. See shopify.env or woocommerce.env.
PLATFORM=shopify            # shopify | woocommerce

# Which payment provider to load. See nexus.env.
PAYMENT_PROVIDER=nexus       # nexus (more coming)

# -----------------------------------------------------------------------------
# Merchant identity
# -----------------------------------------------------------------------------
# DID-style identifier advertised to payment handlers and webhooks.
# Format: did:<method>:<chain-hint>:<slug>
# Where: you define this; stable across deploys.
MERCHANT_DID=did:example:my-store

# -----------------------------------------------------------------------------
# HTTP transport
# -----------------------------------------------------------------------------
TRANSPORT=http               # http | stdio
PORTAL_PORT=10000

# Publicly reachable URL of this service (used in UCP discovery endpoint field).
# Dev: http://localhost:10000. Prod: https://api.example.com.
SELF_URL=http://commerce-agent:10000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Postgres — leave empty to fall back to in-memory stores (dev only).
DATABASE_URL=postgresql://user:password@localhost:5432/commerce_agent

# -----------------------------------------------------------------------------
# UCP cart tokens
# -----------------------------------------------------------------------------
# HMAC secret used to sign stateless cart tokens returned by
# POST /ucp/v1/checkout-sessions.
# Get it from: openssl rand -hex 32
UCP_CART_TOKEN_SECRET=
UCP_TOKEN_TTL_SECONDS=900    # 15 minutes

# -----------------------------------------------------------------------------
# Pricing
# -----------------------------------------------------------------------------
# Primary currency this store sells in (3-letter ISO code).
PAYMENT_CURRENCY=XSGD
# MVP fiat→stablecoin conversion rate (dynamic pricing coming later).
CHECKOUT_FIXED_RATE=1.00
CHECKOUT_RATE_LOCK_MINUTES=5

# -----------------------------------------------------------------------------
# Admin portal (optional)
# -----------------------------------------------------------------------------
PORTAL_TOKEN=
